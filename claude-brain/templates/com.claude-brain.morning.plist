<?xml version="1.0" encoding="UTF-8"?>
<!-- Runs morning_agent.py at 08:00 every morning.
     Install:
       cp templates/com.claude-brain.morning.plist ~/Library/LaunchAgents/
       launchctl load ~/Library/LaunchAgents/com.claude-brain.morning.plist
     Unload:
       launchctl unload ~/Library/LaunchAgents/com.claude-brain.morning.plist
     Logs: _meta/morning.log

     BEFORE INSTALLING: replace /path/to/vault with your actual vault path.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude-brain.morning</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>python3</string>
        <string>/path/to/vault/_meta/scripts/morning_agent.py</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>CLAUDE_BRAIN_VAULT</key>
        <string>/path/to/vault</string>
    </dict>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/path/to/vault/_meta/morning.log</string>
    <key>StandardErrorPath</key>
    <string>/path/to/vault/_meta/morning.log</string>
</dict>
</plist>
